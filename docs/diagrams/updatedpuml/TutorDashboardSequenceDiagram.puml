@startuml
!include ../style.puml
skinparam ArrowFontStyle plain

box Logic LOGIC_COLOR_T1
participant ":LogicManager" as LogicManager LOGIC_COLOR
participant ":AddressBookParser" as AddressBookParser LOGIC_COLOR
participant "d:TutorDashboardCommand" as TutorDashboardCommand LOGIC_COLOR
participant "r:CommandResult" as CommandResult LOGIC_COLOR
end box

box Model MODEL_COLOR_T1
participant "m:Model" as Model MODEL_COLOR
end box

[-> LogicManager : execute("tutordashboard")
activate LogicManager

LogicManager -> AddressBookParser : parseCommand(...)
activate AddressBookParser

create TutorDashboardCommand
AddressBookParser -> TutorDashboardCommand
activate TutorDashboardCommand

TutorDashboardCommand --> AddressBookParser
deactivate TutorDashboardCommand

AddressBookParser --> LogicManager : d
deactivate AddressBookParser

LogicManager -> TutorDashboardCommand : execute(m)
activate TutorDashboardCommand

TutorDashboardCommand -> Model : get all staff from address book
activate Model

note right of TutorDashboardCommand: Reads full (unfiltered) list\nto show all teaching staff

Model --> TutorDashboardCommand
deactivate Model

create CommandResult
TutorDashboardCommand -> CommandResult
activate CommandResult

CommandResult --> TutorDashboardCommand
deactivate CommandResult

TutorDashboardCommand --> LogicManager : r
deactivate TutorDashboardCommand

[<-- LogicManager
deactivate LogicManager
@enduml
